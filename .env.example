# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (Docker Compose default)
DATABASE_URL=postgresql://casfin:casfin_dev@db:5432/casfin

# Session
SESSION_SECRET=change-me-in-production-use-long-random-string

# Casso OIDC
CASSO_BASE_URL=https://next.accounts.casso.vn
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret
APP_ID=your-app-id
REDIRECT_URI=http://localhost:3000/api/auth/callback

# Deep link scheme của Expo mobile app
MOBILE_DEEP_LINK_SCHEME=myapp://auth/callback

# Cloudflare R2
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=casfin-uploads
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# BankHub (Casso Transaction API) — credentials riêng, khác với OIDC
BANKHUB_BASE_URL=https://sandbox.bankhub.dev
CASSO_TRANSACTION_CLIENT_ID=your-transaction-client-id
CASSO_TRANSACTION_SECRET_KEY=your-transaction-secret-key
# Deep link callback sau khi user hoàn tất link ngân hàng
BANKHUB_LINK_REDIRECT_URI=http://localhost:3000/api/accounts/link/callback
