generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum AccountType {
  cash
  bank
  credit_card
  e_wallet
}

enum TransactionType {
  income
  expense
  transfer
}

// confirmed        = giao dịch bình thường hoặc đã được match với bank record
// pending_bank_confirm = tạo từ app, chờ cron sync để match với bank record
enum TransactionStatus {
  confirmed
  pending_bank_confirm
}

enum CategoryType {
  income
  expense
}

enum DebtType {
  lend   // mình cho vay
  borrow // mình đi vay
}

enum BudgetPeriod {
  weekly
  monthly
  yearly
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  cassoSub  String   @unique @map("casso_sub")
  email     String
  createdAt DateTime @default(now()) @map("created_at")

  accounts         Account[]
  categories       Category[]
  transactions     Transaction[]
  debts            Debt[]
  budgets          Budget[]
  bankConnections  BankConnection[]
  bankLinkTokens   BankLinkToken[]

  @@map("users")
}

model Account {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  name              String
  type              AccountType
  // balance có thể âm — hợp lệ với credit_card (số dư nợ chưa thanh toán)
  balance           Decimal     @default(0) @db.Decimal(15, 2)
  currency          String      @default("VND")
  // FK tới BankConnection — chỉ set với tài khoản bank/e_wallet được link qua BankHub
  bankConnectionId  String?     @map("bank_connection_id")
  // số tài khoản ngân hàng thực tế (vd: "123456789")
  accountNumber     String?     @map("account_number")
  // tên chủ tài khoản từ ngân hàng (vd: "NGUYEN VAN A")
  accountHolderName String?     @map("account_holder_name")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankConnection    BankConnection? @relation(fields: [bankConnectionId], references: [id], onDelete: SetNull)
  transactions      Transaction[]   @relation("SourceAccount")
  incomingTransfers Transaction[]   @relation("DestinationAccount")

  @@map("accounts")
}

model Category {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  name      String
  icon      String
  type      CategoryType
  // true = được clone từ default khi user đăng ký lần đầu
  isDefault Boolean      @default(false) @map("is_default")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@map("categories")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String          @map("user_id")
  accountId   String          @map("account_id")
  // chỉ dùng khi type = transfer (chuyển khoản nội bộ giữa các ví)
  toAccountId String?         @map("to_account_id")
  type        TransactionType
  amount      Decimal         @db.Decimal(15, 2)
  categoryId  String?         @map("category_id")
  note        String?
  // URL ảnh trên Cloudflare R2
  imageUrl    String?         @map("image_url")
  date        DateTime
  status      TransactionStatus @default(confirmed)
  // set sau khi two-phase dedup match với bank record từ Casso API
  bankReferenceId      String?   @unique @map("bank_reference_id")
  // datetime chính xác có timezone từ BankHub (transactionDateTime)
  transactionDateTime  DateTime? @map("transaction_date_time")
  // số dư tài khoản sau giao dịch này
  runningBalance       Decimal?  @map("running_balance") @db.Decimal(15, 2)
  // tên và ngân hàng của bên đối ứng trong giao dịch
  counterAccountName     String? @map("counter_account_name")
  counterAccountBankName String? @map("counter_account_bank_name")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account   Account   @relation("SourceAccount", fields: [accountId], references: [id])
  toAccount Account?  @relation("DestinationAccount", fields: [toAccountId], references: [id])
  category  Category? @relation(fields: [categoryId], references: [id])

  // index cho list + filter transactions theo user và ngày
  @@index([userId, date(sort: Desc)])
  // index cho dedup: tìm pending_bank_confirm theo account
  @@index([accountId, status])
  @@map("transactions")
}

model Debt {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  contactName     String    @map("contact_name")
  type            DebtType
  // tổng số tiền ban đầu của khoản nợ
  amount          Decimal   @db.Decimal(15, 2)
  // số tiền còn lại chưa trả/chưa đòi được
  remainingAmount Decimal   @map("remaining_amount") @db.Decimal(15, 2)
  note            String?
  dueDate         DateTime? @map("due_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments DebtPayment[]

  @@map("debts")
}

model DebtPayment {
  id        String   @id @default(uuid())
  debtId    String   @map("debt_id")
  amount    Decimal  @db.Decimal(15, 2)
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@map("debt_payments")
}

model Budget {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  categoryId  String       @map("category_id")
  limitAmount Decimal      @map("limit_amount") @db.Decimal(15, 2)
  period      BudgetPeriod

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // 1 user chỉ có 1 budget pot cho mỗi category + period
  @@unique([userId, categoryId, period])
  @@map("budgets")
}

model BankConnection {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  // accessToken từ BankHub — dùng cho mọi lần sync, không cần user xác thực lại
  accessToken    String    @map("access_token")
  // thông tin fiService từ BankHub (vd: code="vietcombank", name="VCB Digibank")
  bankCode       String    @map("bank_code")
  bankName       String    @map("bank_name")
  bankLogoUrl    String?   @map("bank_logo_url")
  maxHistoryDays Int?      @map("max_history_days")
  // dùng để enforce rate limit và truyền fromDate khi sync
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accounts Account[]

  @@map("bank_connections")
}

model BankLinkToken {
  id        String   @id @default(uuid())
  // token ngẫu nhiên truyền vào redirectUri, single-use, TTL 10 phút
  token     String   @unique @default(uuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_link_tokens")
}
